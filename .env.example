# Tributary server configuration — everything is optional; the defaults run a
# fully working single-machine studio. Copy to .env (and export, or use your
# process manager's env handling; the server does not auto-load .env files).

# HTTP + WebSocket port for the API server.
#PORT=4100

# Fastify log level: fatal | error | warn | info | debug | trace
#LOG_LEVEL=info

# Where chunks, assembled media, exports, transcripts, and tributary.db live.
# Defaults to ./data at the repo root.
#TRIBUTARY_DATA_DIR=/var/lib/tributary

# TURN/STUN for guests behind strict NATs (JSON array of RTCIceServer).
# See docs/DEPLOYMENT.md for a coturn recipe.
#ICE_SERVERS=[{"urls":"turn:turn.example.com:3478","username":"tributary","credential":"..."}]

# Optional LiveKit SFU — scales the live call past the ~6-participant mesh
# ceiling. Local recording/upload is unaffected. All three must be set.
#LIVEKIT_URL=wss://your-livekit-host
#LIVEKIT_API_KEY=
#LIVEKIT_API_SECRET=

# Post-production toolchain. Defaults assume ffmpeg/ffprobe on PATH.
#FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
#FFPROBE_PATH=/opt/homebrew/bin/ffprobe

# Transcription via whisper.cpp (`brew install whisper-cpp`). The model file
# auto-downloads to $TRIBUTARY_DATA_DIR/models on first use.
#WHISPER_CLI=whisper-cli
#WHISPER_MODEL=/path/to/ggml-base.bin

# --- CLI only (the `tributary` command, not the server) ---
# Defaults for `tributary --server` and stored auth; see docs/AI-AGENTS.md.
#TRIBUTARY_SERVER=http://localhost:4100
#TRIBUTARY_TOKEN=
#TRIBUTARY_PASSWORD=
